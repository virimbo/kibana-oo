# ============================================
# KIBANA-OO Configuration
# Copy this file to .env
# ============================================

# Kibana URL (your Kibana instance)
KIBANA_URL=https://kibana-prod.cicd.s15m.nl

# Kibana space
KIBANA_SPACE=koop-plooi-prod

# Index pattern (found in Kibana > Discover dropdown)
ES_LOG_INDEX=logs-*
ES_METRIC_INDEX=logs-*

# Data views the user can pick from (comma-separated ES index patterns).
# Acts as a whitelist — only these may be queried. DEFAULT_DATA_VIEW must be one of them.
DATA_VIEWS=logs-*,ds-prod5-koop-plooi*,ds-prod5-koop-sp
DEFAULT_DATA_VIEW=logs-*

# Dashboard (admin monitoring)
DASHBOARD_CACHE_TTL=60
DASHBOARD_TIMEZONE=Europe/Amsterdam
# Comma-separated admin usernames/emails allowed to see the dashboard.
DASHBOARD_ADMINS=anton.partono@koop.overheid.nl
# Super admins (comma-separated emails): root of trust — every feature implicitly,
# and the only ones who can manage the authorisation matrix. See docs/authorization.md.
SUPER_ADMINS=anton.partono@koop.overheid.nl

# RabbitMQ DLQ monitor — read-only Management-API monitoring of dead-letter queues.
# Inert until user + password are set. Needs network reach to the broker (VPN).
RABBITMQ_API_URL=https://rabbitmq.koop-plooi-prd.prod5.s15m.nl
RABBITMQ_USER=
RABBITMQ_PASSWORD=
RABBITMQ_DLQ_SUFFIX=.dlq
RABBITMQ_CRITICAL_MESSAGES=100
RABBITMQ_POLL_INTERVAL_MINUTES=5
RABBITMQ_ALERT_ENABLED=true
# Views excluded from rollup totals to avoid double counting (still shown per-system).
DASHBOARD_SUPERSET_VIEWS=logs-*
# Index patterns where TLS certificate monitoring (Heartbeat/Synthetics) data lives,
# used for the certificate-expiry cards.
CERT_INDEX=heartbeat-*,synthetics-*
# Public hosts actively audited (chain, trust, revocation, protocols, expiry).
CERT_PROBE_HOSTS=open.overheid.nl,doculoket.overheid.nl
CERT_PROBE_TIMEOUT=6.0
CERT_CHECK_REVOCATION=true
# Daily proactive audit: re-check every host on this interval (hours) and alert
# (via the digest webhook / email) when a host grades WARN or CRITICAL.
CERT_AUDIT_INTERVAL_HOURS=24
CERT_ALERT_ENABLED=true

# Aanleverfouten monitor — documents rejected at delivery/intake. Detected in the
# logs, reconciled against open.overheid.nl, tracked as durable incidents.
AANLEVER_ENABLED=true
AANLEVER_DATA_VIEW=ds-prod5-koop-plooi*
AANLEVER_LOOKBACK_HOURS=48
# Structured status field (most precise) — set if the logs carry one, else leave
# empty to use the stage + message-pattern fallback below. Tune to the real logs.
AANLEVER_STATUS_FIELD=
AANLEVER_STATUS_VALUES=aanleverfout,afgekeurd,geweigerd,rejected,invalid
AANLEVER_SERVICES=doculoket,aanlever,aanlevering,gateway,ingest,intake
AANLEVER_PATTERNS=aanleverfout,afgekeurd,geweigerd,validatie,validation,schema,herstel,opnieuw aanleveren,rejected,invalid,niet geldig
AANLEVER_SETTLE_MINUTES=10
AANLEVER_ALERT_ENABLED=true

# Regression test (post-release health gate for the public portal).
REGRESSION_TARGET_URL=https://open.overheid.nl
# A known published document (UUID) used by the content-correctness checks.
REGRESSION_KNOWN_DOC_ID=1a7e9fc7-0be6-4815-90a9-e733d79a5f07
# Set a secret to enable the CI trigger: POST /regression/trigger with header
# X-Regression-Token: <this value>. Leave empty to disable that endpoint.
REGRESSION_TRIGGER_TOKEN=
REGRESSION_ALERT_ENABLED=true
# Keep at most this many runs; pruning drops oldest PASS first (failures kept longest).
REGRESSION_HISTORY_CAP=1000

# Document processing pipelines (Verwerkingsstraat): OVS = oude (old), NVS = nieuwe (new).
# Query strings that attribute documents to each pipeline — tune to match your logs.
PIPELINE_OVS_QUERY=OVS OR "oude verwerkingsstraat"
PIPELINE_NVS_QUERY=NVS OR "nieuwe verwerkingsstraat"

# Reliable per-document NVS/OVS attribution (for the "Pipeline health" list).
# Classified in order of TRUST; configure either layer to make it authoritative
# (a document that matches neither is then shown as "—", never guessed).
#   1) A dedicated field your logs carry. Set its dotted name(s), comma-separated,
#      and the values that mean each pipeline. Leave empty to skip this layer.
PIPELINE_FIELD=
PIPELINE_NVS_VALUES=nvs,nieuwe verwerkingsstraat,nieuwe
PIPELINE_OVS_VALUES=ovs,oude verwerkingsstraat,oude
#   2) The index / data-stream the events live in (structural). List substrings
#      that identify each pipeline's index. Example: PIPELINE_NVS_INDEX=koop-plooi
PIPELINE_NVS_INDEX=
PIPELINE_OVS_INDEX=
#   3) Publication-date cutoff (the pipeline switchover). A document active/
#      published ON OR AFTER this date is NVS; before it, OVS. This is the
#      authoritative KOOP Plooi rule. Set empty to disable. (ISO date.)
PIPELINE_NVS_CUTOFF=2026-04-28

# Public portal base for building clickable document links (404 list, OVS drill-down).
PORTAL_BASE_URL=https://open.overheid.nl
# Best-effort source fields to identify documents in drill-down lists (tune to your logs).
DOC_URL_FIELDS=url.full,url.original,url.path
DOC_ID_FIELDS=document.id,documentId,dossier.id,identifier,id
DOC_TITLE_FIELDS=title,titel,document.title,name
DOC_ACTION_FIELDS=event.action,event.type,action,operation,mutatie
# Extract a document id from the log text and build a portal link (KOOP "ronl-..." ids).
DOC_ID_REGEX=ronl-[A-Za-z0-9-]+
DOC_LINK_TEMPLATE=https://open.overheid.nl/documenten/{id}

# Documents activity tab: which logs count as document events, and feed size.
DOCUMENT_EVENT_QUERY=ronl OR document OR bestand OR upload OR publicatie OR versie
DOCUMENT_EVENT_SIZE=200
# Best-effort source fields for a document's organization (tune to your logs).
DOC_ORG_FIELDS=organisatie,bronorganisatie,publisher,organization,source.organization,verantwoordelijke,bron,afzender
# Known document sources (bron) for the errors-by-source table.
PROCESSING_SOURCES=aanleverloket,dpc,oep-ob,oep,plooi-api,ronl-archief,ronl,roo,woo-idx

# LLM settings (no need to change these)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# Mistral AI settings (alternative to Ollama)
# Get your API key from https://console.mistral.ai/
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-large-latest

# LLM Provider: "ollama" (default, local) or "mistral" (cloud API)
LLM_PROVIDER=ollama

# Backend (no need to change these)
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
