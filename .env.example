# Elasticsearch connection
# The ES endpoint behind your Kibana instance
ELASTICSEARCH_URL=https://elasticsearch-prod.cicd.s15m.nl:9200
ELASTICSEARCH_API_KEY=your-api-key-here
# Or use basic auth instead of API key:
# ELASTICSEARCH_USER=your-username
# ELASTICSEARCH_PASSWORD=your-password

# Kibana space (extracted from your URL)
KIBANA_SPACE=koop-plooi-prod

# Elasticsearch index patterns for logs and metrics
ES_LOG_INDEX=filebeat-*,logs-*
ES_METRIC_INDEX=metricbeat-*,metrics-*

# LLM settings
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# Backend
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
