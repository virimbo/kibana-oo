# ============================================
# KIBANA-OO Configuration
# Copy this file to .env and fill in your values
# ============================================

# Your Kibana/Elasticsearch login credentials
ELASTICSEARCH_USER=your-kibana-username
ELASTICSEARCH_PASSWORD=your-kibana-password

# Elasticsearch URL (the server behind your Kibana)
ELASTICSEARCH_URL=https://elasticsearch-prod.cicd.s15m.nl:9200

# Index pattern (found in Kibana > Discover dropdown)
ES_LOG_INDEX=logs-*
ES_METRIC_INDEX=logs-*

# Kibana space
KIBANA_SPACE=koop-plooi-prod

# LLM settings (no need to change these)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# Backend (no need to change these)
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
